{
  "name": "workspacecord-monorepo",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xuhongbo/WorkspaceCord.git"
  },
  "scripts": {
    "build": "pnpm --filter workspacecord run build",
    "start": "NODE_ENV=development node --experimental-strip-types packages/cli/src/cli.ts",
    "dev": "pnpm --filter workspacecord run dev",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration:smoke": "node --experimental-strip-types scripts/integration-smoke.ts",
    "test:multi-session:smoke": "node --experimental-strip-types scripts/multi-session-smoke.ts",
    "test:session-sync:smoke": "node --experimental-strip-types scripts/session-sync-smoke.ts",
    "test:monitor:e2e": "node --experimental-strip-types scripts/monitor-e2e.ts",
    "test:output-port:e2e": "node --experimental-strip-types scripts/output-port-e2e.ts",
    "test:startup-flow:e2e": "node --experimental-strip-types scripts/startup-flow-e2e.ts",
    "test:gate:e2e": "node --experimental-strip-types scripts/gate-e2e.ts",
    "test:acceptance:local": "node --experimental-strip-types scripts/local-acceptance-suite.ts",
    "release": "node --experimental-strip-types scripts/release.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.85",
    "@clack/prompts": "^1.1.0",
    "cac": "^7.0.0",
    "configstore": "^8.0.0",
    "discord.js": "^14.25.1",
    "execa": "^9.6.1",
    "pino": "^10.3.1",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/configstore": "^6.0.2",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=22.6.0"
  },
  "version": "1.1.1"
}
